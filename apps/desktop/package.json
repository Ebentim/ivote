{
  "name": "desktop",
  "version": "1.0.0",
  "description": "iVote Desktop (Electron)",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"pnpm --filter web dev\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "pnpm --filter web build && electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "electron": "^32.2.5",
    "electron-builder": "^25.1.8",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.alpinesbolt.ivote",
    "productName": "iVote",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "!../web/src"
    ],
    "extraResources": [
      {
        "from": "../web/dist",
        "to": "web"
      }
    ],
    "mac": {
      "target": "zip",
      "category": "public.app-category.business",
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  }
}
