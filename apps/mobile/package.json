{
  "name": "mobile",
  "version": "1.0.0",
  "description": "iVote Mobile (Capacitor)",
  "private": true,
  "scripts": {
    "build": "pnpm --filter web build",
    "sync": "pnpm build && cap sync",
    "sync:android": "pnpm build && cap sync android",
    "sync:ios": "pnpm build && cap sync ios",
    "open:android": "cap open android",
    "open:ios": "cap open ios",
    "run:android": "cap run android",
    "run:ios": "cap run ios",
    "cap": "cap"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/app": "^6.0.1",
    "@capacitor/core": "^6.1.2",
    "@capacitor/haptics": "^6.0.1",
    "@capacitor/ios": "^6.1.2",
    "@capacitor/keyboard": "^6.0.2",
    "@capacitor/status-bar": "^6.0.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2"
  }
}
