# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=development        # development | production
PORT=8080
BASE_URL=http://localhost:8080

# ─── Database ─────────────────────────────────────────────────────────────────
# iVote supports three ways to configure the database.
# Priority: DATABASE_URL → DB_URL → individual vars (DB_HOST etc.)
# Only one block is needed — pick whichever matches your setup.

# ── Option A: Supabase / Neon / Railway / managed Postgres ───────────────────
# Paste the full connection string from your provider dashboard.
# Both postgres:// and postgresql:// schemes are accepted.
#
# Supabase (Settings → Database → Connection string → URI):
# DATABASE_URL=postgres://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
#
# Neon (Dashboard → Connection Details → Connection string):
# DATABASE_URL=postgres://[user]:[password]@[endpoint].neon.tech/[dbname]?sslmode=require
#
# Generic:
# DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# ── Option B: DB_URL alias (some providers use this name) ────────────────────
# DB_URL=postgres://user:password@host:5432/dbname?sslmode=require

# ── Option C: Individual vars (local / self-hosted / Docker) ─────────────────
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=changeme
# DB_NAME=ivote
# DB_SSLMODE=disable    # use 'require' for production / managed hosts

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 64
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# ─── Vote anonymisation pepper ────────────────────────────────────────────────
# Generate: openssl rand -hex 32
# WARNING: changing this after votes are cast will break duplicate-vote detection
VOTE_PEPPER=change-this-pepper-in-production

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Exactly one allowed origin. Must match the URL your frontend is served from.
CORS_ORIGIN=http://localhost:5173

# ─── Superadmin seed (applied only on first run) ──────────────────────────────
SUPERADMIN_USERNAME=admin
SUPERADMIN_PASSWORD=changeme123!
SUPERADMIN_EMAIL=admin@ivote.local
SUPERADMIN_NAME=System Administrator

# ─── File uploads ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
